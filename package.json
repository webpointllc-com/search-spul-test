{
  "name": "search-spul",
  "version": "1.0.0",
  "description": "Generative AI search-to-chat interface - Search Spul",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "verify:golden": "node scripts/verify-golden-counties.js",
    "import:master": "node scripts/import-master-counties.js",
    "import:master:dry": "node scripts/import-master-counties.js --dry-run",
    "validate:batch": "node scripts/validate-counties-batch.js",
    "test:scenarios": "node scripts/test-scenarios.js",
    "validate:pay-taxes": "node scripts/validate-pay-taxes-search.js",
    "queue:list": "node scripts/queue-correction.js list",
    "queue:apply-next": "node scripts/queue-correction.js apply-next",
    "queue:ingest-failures": "node scripts/ingest-validation-failures.js",
    "queue:ingest-failures:dry": "node scripts/ingest-validation-failures.js --dry-run",
    "ingest:validation-failures": "node scripts/ingest-validation-failures.js --also-bad-assessor"
  },
  "dependencies": {
    "cookie-session": "^2.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^4.52.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}